generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String    @id @default(uuid())
  name                    String
  email                   String    @unique
  password                String
  phone                   String
  role                    UserRole  @default(USER)
  isEmailVerified         Boolean   @default(false)
  emailVerificationToken  String?
  emailVerificationExpiry DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  deletedAt               DateTime?
  bookings                Booking[]
  vehicles                Vehicle[]

  @@map("users")
}

model Vehicle {
  id            String      @id @default(uuid())
  userId        String
  vehicleNumber String      @unique
  vehicleType   VehicleType
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?
  bookings      Booking[]
  user          User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("vehicles")
}

model ParkingLot {
  id           String    @id @default(uuid())
  name         String
  description  String?
  address      String
  city         String
  state        String
  latitude     Float
  longitude    Float
  pricePerHour Decimal
  gracePeriodMinutes  Int      @default(15)

  overstayRate        Decimal @default(100)
  totalSlots   Int
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  slots    ParkingSlot[]
  bookings Booking[]

  @@map("parking_lots")
}

model ParkingSlot {
  id          String     @id @default(uuid())
  lotId       String
  floorNumber Int        @default(1)
  slotNumber  String
  slotType    SlotType
  status      SlotStatus @default(AVAILABLE)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
  bookings    Booking[]
  lot         ParkingLot @relation(fields: [lotId], references: [id])

  @@unique([lotId, floorNumber, slotNumber])
  @@index([lotId])
  @@map("parking_slots")
}

model Booking {
  id String @id @default(uuid())

  userId    String
  vehicleId String
  lotId     String
  slotId    String

  bookingReference String @unique

  durationHours Int

  startTime DateTime
  endTime   DateTime

  totalAmount Decimal
  
  overstayMinutes Int @default(0)

  overstayAmount Decimal @default(0)

  bookingStatus BookingStatus @default(PENDING_PAYMENT)

  expiresAt DateTime?

  qrToken String? @unique
  qrExpiresAt DateTime?

  entryTime DateTime?
  exitTime  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User        @relation(fields: [userId], references: [id])
  vehicle Vehicle     @relation(fields: [vehicleId], references: [id])
  lot     ParkingLot  @relation(fields: [lotId], references: [id])
  slot    ParkingSlot @relation(fields: [slotId], references: [id])



  payments Payment[]

  @@index([bookingStatus, endTime])
  @@index([userId])
  @@index([vehicleId])
  @@index([lotId])
  @@index([slotId])
  @@index([bookingStatus])
  @@map("bookings")
}

model Payment {

  id String @id @default(uuid())

  bookingId String


  razorpayOrderId String?

  razorpayPaymentId String?

  razorpaySignature String?   

  amount Decimal

  description String?

  currency String @default("INR")

  paymentMethod PaymentMethod?

  paymentStatus PaymentStatus @default(PENDING)


  paymentType PaymentType @default(BOOKING)
  paidAt DateTime?

  failureReason String?

  refundedAt DateTime?
  refundAmount Decimal? @default(0)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  booking Booking @relation(fields:[bookingId],references:[id])

  @@index([paymentStatus])
  @@index([bookingId, paymentType])
  @@index([paymentType])
  @@index([bookingId])

  @@map("payments")
}

enum UserRole {
  USER
  ADMIN
}

enum VehicleType {
  CAR
  BIKE
  EV
}

enum SlotType {
  CAR
  BIKE
  EV
  DISABLED
}

enum SlotStatus {
  AVAILABLE
  TEMP_RESERVED
  RESERVED
  OCCUPIED
  MAINTENANCE
}

enum BookingStatus {

PENDING_PAYMENT

CONFIRMED

ACTIVE

OVERSTAY_PAYMENT_PENDING

COMPLETED

CANCELLED

EXPIRED

}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  UPI
  NET_BANKING
  WALLET
}



enum PaymentType {
  BOOKING
  OVERSTAY
  REFUND
}
